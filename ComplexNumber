        { text: "Factor \\(z^2 + z + 1\\) over complex numbers:", options: ["\\(\\left(z - \\frac{-1 + i\\sqrt{3}}{2}\\right)\\left(z - \\frac{-1 - i\\sqrt{3}}{2}\\right)\\)", "\\(\\left(z - \\frac{1 + i\\sqrt{3}}{2}\\right)\\left(z - \\frac{1 - i\\sqrt{3}}{2}\\right)\\)", "\\((z - i)(z + i)\\)", "\\((z - \\sqrt{3}i)(z + \\sqrt{3}i)\\)"], correct: 0 },
        // Q83
        { text: "Factor \\(z^4 - 1\\) over complex numbers:", options: ["\\((z-1)(z+1)(z-i)(z+i)\\)", "\\((z-1)^2(z+1)^2\\)", "\\((z^2-1)(z^2+1)\\)", "\\((z-1)(z+1)(z^2+1)\\)"], correct: 0 },
        // Q84
        { text: "The roots of \\(z^2 + 4z + 13 = 0\\) are:", options: ["\\(-2 \\pm 3i\\)", "\\(2 \\pm 3i\\)", "\\(-3 \\pm 2i\\)", "\\(3 \\pm 2i\\)"], correct: 0 },
        // Q85
        { text: "A polynomial with roots \\(i\\) and \\(-i\\) is:", options: ["\\(z^2 + 1\\)", "\\(z^2 - 1\\)", "\\(z^2 + i\\)", "\\(z^2 - i\\)"], correct: 0 },
        // Q86
        { text: "A polynomial with roots \\(1+i\\) and \\(1-i\\) is:", options: ["\\(z^2 - 2z + 2\\)", "\\(z^2 + 2z + 2\\)", "\\(z^2 - 2z - 2\\)", "\\(z^2 + 2z - 2\\)"], correct: 0 },
        // Q87
        { text: "Factor \\(z^2 + (2+i)z + 2i\\) over complex numbers:", options: ["\\((z+i)(z+2)\\)", "\\((z-i)(z+2)\\)", "\\((z+2i)(z+1)\\)", "\\((z-2i)(z-1)\\)"], correct: 0 },
        // Q88
        { text: "Solve for \\(z\\): <br> \\( z + \\overline{z} = 4 \\) <br> \\( z - \\overline{z} = 2i \\)", options: ["\\(z = 2 + i\\)", "\\(z = 2 - i\\)", "\\(z = 1 + 2i\\)", "\\(z = 1 - 2i\\)"], correct: 0 },
        // Q89
        { text: "Solve for \\(z\\) and \\(w\\): <br> \\( z + i w = 1 + i \\) <br> \\( i z + w = 1 - i \\)", options: ["\\(z = 1, w = i\\)", "\\(z = 1, w = -i\\)", "\\(z = i, w = 1\\)", "\\(z = -i, w = 1\\)"], correct: 0 },
        // Q90
        { text: "Factor \\(z^3 - 2z^2 + 2z\\) over complex numbers:", options: ["\\(z(z-(1+i))(z-(1-i))\\)", "\\(z(z+(1+i))(z+(1-i))\\)", "\\(z(z-(2+i))(z-(2-i))\\)", "\\(z(z+(2+i))(z+(2-i))\\)"], correct: 0 },
        // Q91
        { text: "The roots of \\(z^4 + 4 = 0\\) are:", options: ["\\(\\pm 1 \\pm i\\)", "\\(\\pm \\sqrt{2} \\pm i\\sqrt{2}\\)", "\\(\\pm 2 \\pm 2i\\)", "\\(\\pm 1 \\pm \\sqrt{2}i\\)"], correct: 0 },
        // Q92
        { text: "Factor \\(z^2 + 6z + 10\\) over complex numbers:", options: ["\\((z+3+i)(z+3-i)\\)", "\\((z-3+i)(z-3-i)\\)", "\\((z+3+2i)(z+3-2i)\\)", "\\((z-3+2i)(z-3-2i)\\)"], correct: 0 },
        // Q93
        { text: "Solve for \\(z\\) and \\(w\\): <br> \\( (1+i)z + (1-i)w = 4 \\) <br> \\( (1-i)z + (1+i)w = 4i \\)", options: ["\\(z = 1+i, w = 1-i\\)", "\\(z = 1-i, w = 1+i\\)", "\\(z = 2, w = 2i\\)", "\\(z = 2i, w = 2\\)"], correct: 0 },
        // Q94
        { text: "Factor \\(z^2 + 9\\) over complex numbers:", options: ["\\((z+3i)(z-3i)\\)", "\\((z+3)(z-3)\\)", "\\((z+9i)(z-9i)\\)", "\\((z+9)(z-9)\\)"], correct: 0 },
        // Q95
        { text: "The quadratic equation whose roots are \\(2+i\\) and \\(2-i\\) is:", options: ["\\(z^2 - 4z + 5 = 0\\)", "\\(z^2 + 4z + 5 = 0\\)", "\\(z^2 - 4z - 5 = 0\\)", "\\(z^2 + 4z - 5 = 0\\)"], correct: 0 },
        // Q96
        { text: "Factor \\(z^3 + 2z^2 + z + 2\\) over complex numbers:", options: ["\\((z+2)(z^2+1)\\)", "\\((z-2)(z^2+1)\\)", "\\((z+2)(z^2-1)\\)", "\\((z-2)(z^2-1)\\)"], correct: 0 },
        // Q97
        { text: "Solve for \\(z\\) and \\(w\\): <br> \\( z + w = 2i \\) <br> \\( iz - iw = 2 \\)", options: ["\\(z = 1+i, w = -1+i\\)", "\\(z = 1-i, w = -1-i\\)", "\\(z = 1+i, w = 1-i\\)", "\\(z = -1+i, w = 1+i\\)"], correct: 0 },
        // Q98
        { text: "The roots of \\(z^2 + 2z + 2 = 0\\) are:", options: ["\\(-1 \\pm i\\)", "\\(1 \\pm i\\)", "\\(-2 \\pm i\\)", "\\(2 \\pm i\\)"], correct: 0 },
        // Q99
        { text: "Factor \\(z^2 - 4z + 13\\) over complex numbers:", options: ["\\((z-2+3i)(z-2-3i)\\)", "\\((z+2+3i)(z+2-3i)\\)", "\\((z-3+2i)(z-3-2i)\\)", "\\((z+3+2i)(z+3-2i)\\)"], correct: 0 },
        // Q100
        { text: "If \\(z\\) is a root of \\(z^2 + z + 1 = 0\\), then the value of \\(z^{2024} + z^{2023} + 1\\) is:", options: ["0", "1", "2", "3"], correct: 0 }
    ];

    // -------------------------------------------------------------
    // RENDER ALL QUESTIONS
    // -------------------------------------------------------------
    const container = document.getElementById('questionsContainer');
    let html = '';
    questions.forEach((q, index) => {
        const qNum = index + 1;
        html += `<div class="question-block" id="q${qNum}">`;
        html += `<div class="q-header"><span class="q-number">${qNum}.</span> <span class="q-text">${q.text}</span></div>`;
        html += `<div class="options">`;
        const letters = ['A', 'B', 'C', 'D'];
        q.options.forEach((opt, optIndex) => {
            const radioId = `q${qNum}_${optIndex}`;
            html += `<label class="option-label" for="${radioId}">`;
            html += `<input type="radio" name="q${qNum}" id="${radioId}" value="${optIndex}">`;
            html += `<span>${letters[optIndex]}. ${opt}</span>`;
            html += `</label>`;
        });
        html += `</div></div>`;
    });
    container.innerHTML = html;

    // -------------------------------------------------------------
    // SUBMIT FUNCTION
    // -------------------------------------------------------------
    function submitTest() {
        let correct = 0, wrong = 0, unattempted = 0;
        const total = questions.length;
        for (let i = 0; i < total; i++) {
            const qNum = i + 1;
            const radios = document.getElementsByName(`q${qNum}`);
            let selected = null;
            for (const radio of radios) {
                if (radio.checked) {
                    selected = parseInt(radio.value);
                    break;
                }
            }
            if (selected === null) {
                unattempted++;
            } else if (selected === questions[i].correct) {
                correct++;
            } else {
                wrong++;
            }
        }
        const score = correct - 0.25 * wrong;
        // Display result
        const resultDiv = document.getElementById('result');
        resultDiv.style.display = 'block';
        document.getElementById('scoreDisplay').textContent = `${score.toFixed(2)} / ${total}`;
        document.getElementById('detailDisplay').textContent = `You got ${correct} correct, ${wrong} wrong, and ${unattempted} unattempted.`;
        document.getElementById('correctCount').textContent = correct;
        document.getElementById('wrongCount').textContent = wrong;
        document.getElementById('unattemptedCount').textContent = unattempted;

        // Scroll to result
        resultDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
</script>
</body>
</html>
